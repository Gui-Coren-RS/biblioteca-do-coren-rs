{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered employee",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "createdAt"]
    },
    "Book": {
      "title": "Book",
      "description": "A book registered for lending",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "synopsis": { "type": "string" },
        "author": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerName": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "borrowerId": { "type": "string" },
        "borrowerName": { "type": "string" },
        "loanDate": { "type": "string", "format": "date-time" },
        "returnDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["disponível", "emprestado", "em processo de empréstimo"] },
        "ownerConfirmed": { "type": "boolean" },
        "borrowerConfirmed": { "type": "boolean" },
        "waitlist": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uid": { "type": "string" },
              "name": { "type": "string" },
              "email": { "type": "string" }
            },
            "required": ["uid", "name", "email"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerId", "ownerName", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/books/{bookId}": {
      "schema": { "$ref": "#/entities/Book" },
      "description": "Books available for lending"
    }
  }
}
